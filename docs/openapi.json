{
  "openapi": "3.0.3",
  "info": {
    "title": "Telemedicina LUI API",
    "description": "API REST del backend (Express). Autenticación JWT. Usa **Authorize** con el token devuelto por login o registro.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "Mismo origen (p. ej. http://localhost:5000)"
    }
  ],
  "tags": [
    { "name": "Sistema", "description": "Salud del servicio" },
    { "name": "Auth", "description": "Registro, login y perfil" },
    { "name": "Citas", "description": "Citas médicas" },
    { "name": "Historial", "description": "Historial clínico (médico / paciente)" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ErrorMessage": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "message": { "type": "string" }
        }
      },
      "LoginBody": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "format": "password" }
        }
      },
      "RegisterBody": {
        "type": "object",
        "required": ["nombre", "apellido", "email", "password"],
        "properties": {
          "nombre": { "type": "string" },
          "apellido": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "format": "password" },
          "role": {
            "type": "string",
            "enum": ["Paciente", "Medico", "Administrador"],
            "default": "Paciente"
          },
          "especialidad": { "type": "string", "description": "Recomendado si role es Medico" },
          "telefono": { "type": "string" }
        }
      },
      "CreateAppointmentBody": {
        "type": "object",
        "required": ["medicoId", "fechaHora", "motivoConsulta"],
        "properties": {
          "medicoId": { "type": "string", "description": "ObjectId del médico" },
          "fechaHora": { "type": "string", "format": "date-time" },
          "motivoConsulta": { "type": "string" },
          "pacienteId": {
            "type": "string",
            "description": "Solo si el token es Administrador (no Paciente)"
          }
        }
      },
      "UpdateAppointmentStatusBody": {
        "type": "object",
        "required": ["estado"],
        "properties": {
          "estado": {
            "type": "string",
            "enum": ["Programada", "Completada", "Cancelada"]
          }
        }
      }
    }
  },
  "paths": {
    "/api/health": {
      "get": {
        "tags": ["Sistema"],
        "summary": "Estado del API",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ok" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Registro de usuario",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegisterBody" }
            }
          }
        },
        "responses": {
          "201": { "description": "Usuario creado" },
          "400": {
            "description": "Usuario ya existe u error de validación",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorMessage" }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Iniciar sesión",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginBody" }
            }
          }
        },
        "responses": {
          "200": { "description": "Token JWT en el cuerpo" },
          "401": {
            "description": "Credenciales inválidas",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorMessage" }
              }
            }
          }
        }
      }
    },
    "/api/auth/profile": {
      "get": {
        "tags": ["Auth"],
        "summary": "Perfil del usuario autenticado",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Perfil" },
          "401": { "description": "No autorizado" }
        }
      }
    },
    "/api/auth/medicos": {
      "get": {
        "tags": ["Auth"],
        "summary": "Listado de médicos",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Lista de médicos" },
          "401": { "description": "No autorizado" }
        }
      }
    },
    "/api/auth/admin-dashboard": {
      "get": {
        "tags": ["Auth"],
        "summary": "Ejemplo ruta solo Administrador",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "OK" },
          "401": { "description": "No autorizado" },
          "403": { "description": "Rol insuficiente" }
        }
      }
    },
    "/api/appointments": {
      "get": {
        "tags": ["Citas"],
        "summary": "Mis citas (según rol)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Lista de citas" },
          "401": { "description": "No autorizado" }
        }
      },
      "post": {
        "tags": ["Citas"],
        "summary": "Crear cita (Paciente o Administrador)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateAppointmentBody" }
            }
          }
        },
        "responses": {
          "201": { "description": "Cita creada" },
          "401": { "description": "No autorizado" },
          "403": { "description": "Rol no permitido" },
          "409": { "description": "Horario no disponible: el médico ya tiene cita confirmada en esa fecha y hora" }
        }
      }
    },
    "/api/appointments/{id}/status": {
      "put": {
        "tags": ["Citas"],
        "summary": "Actualizar estado de la cita (Médico o Administrador)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "ObjectId de la cita"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateAppointmentStatusBody" }
            }
          }
        },
        "responses": {
          "200": { "description": "Cita actualizada" },
          "404": { "description": "Cita no encontrada" },
          "401": { "description": "No autorizado" },
          "403": { "description": "Rol no permitido" }
        }
      }
    },
    "/api/historial": {
      "post": {
        "tags": ["Historial"],
        "summary": "Crear registro médico (solo Médico)",
        "description": "Campos de texto como partes del formulario; archivo opcional.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "pacienteId",
                  "motivoConsulta",
                  "diagnostico",
                  "tratamiento"
                ],
                "properties": {
                  "pacienteId": { "type": "string" },
                  "citaId": { "type": "string" },
                  "motivoConsulta": { "type": "string" },
                  "diagnostico": { "type": "string" },
                  "tratamiento": { "type": "string" },
                  "notasEvolutivas": { "type": "string" },
                  "archivo": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Registro creado" },
          "401": { "description": "No autorizado" },
          "403": { "description": "Solo médicos" },
          "404": { "description": "Paciente no encontrado" }
        }
      }
    },
    "/api/historial/paciente/{id}": {
      "get": {
        "tags": ["Historial"],
        "summary": "Historial de un paciente",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "ObjectId del paciente"
          }
        ],
        "responses": {
          "200": { "description": "Lista de registros" },
          "403": { "description": "Paciente viendo otro id" },
          "401": { "description": "No autorizado" }
        }
      }
    }
  }
}
